# Copy to .env and fill in values. Never commit .env or real credentials.
# On Vercel: set these in Project → Settings → Environment Variables.

# Server port (default 4321)
PORT=4321

# Gmail OAuth (for email sending) — optional
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URL=
GMAIL_REFRESH_TOKEN=
GMAIL_EMAIL=

# Firebase Admin (for Google login) — optional; or use backend/serviceAccountKey.json locally
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
